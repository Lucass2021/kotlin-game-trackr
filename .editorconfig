root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{kt,kts}]
indent_size = 4
max_line_length = 160
ktlint_code_style = ktlint_official
# @Composable functions are PascalCase by convention (official Compose style).
ktlint_standard_function-naming = disabled

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
